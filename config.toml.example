# agent-inject configuration (TOML format)
#
# Place this file at:
#   Linux:   ~/.config/agent-inject/config.toml
#   macOS:   ~/Library/Application Support/agent-inject/config.toml
#   Windows: %APPDATA%/agent-inject/config.toml
#
# Or specify explicitly: agent-inject scan --config /path/to/config.toml
#
# Priority: CLI flags > env vars > .env file > this TOML > defaults
# TOML keys use field names directly (no AGENT_INJECT_ prefix).

[target]
# url = "https://your-agent.example.com/chat"
# adapter = "rest"
# timeout_seconds = 30.0

[engine]
# max_concurrent = 5
# max_turns = 15

[output]
# dir = "./results"
# format = "json"
# verbose = false

[scoring]
# canary_match_threshold = 0.8
# use_llm_judge = false
# judge_model = "gpt-4o-mini"

[secrets]
# Prefer env vars or a secrets manager for API keys.
# openai_api_key = "sk-..."
# anthropic_api_key = "sk-ant-..."
