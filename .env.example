# agent-inject configuration template
#
# SECURITY: This file is NOT auto-loaded from the current directory (CWE-426).
# To use:  agent-inject scan --env-file /path/to/.env ...
# Or place in your XDG config dir:
#   Linux:   ~/.config/agent-inject/.env
#   macOS:   ~/Library/Application Support/agent-inject/.env
#   Windows: %APPDATA%/agent-inject/.env
#
# Env vars use double underscore (__) as nested delimiter.
# See: https://github.com/isaacschepp/agent-inject/issues/466

# === Target Configuration ===
# AGENT_INJECT_TARGET__URL=https://your-agent.example.com/chat
# AGENT_INJECT_TARGET__ADAPTER=rest
# AGENT_INJECT_TARGET__TIMEOUT_SECONDS=30.0
# AGENT_INJECT_TARGET__MESSAGE_FIELD=message
# AGENT_INJECT_TARGET__RESPONSE_FIELD=response

# === Engine Configuration ===
# AGENT_INJECT_ENGINE__MAX_CONCURRENT=5
# AGENT_INJECT_ENGINE__MAX_TURNS=15
# AGENT_INJECT_ENGINE__MAX_BACKTRACKS=5
# AGENT_INJECT_ENGINE__MAX_RETRIES=3
# AGENT_INJECT_ENGINE__RETRY_BACKOFF_SECONDS=2.0

# === API Keys (use a secrets manager in production) ===
# AGENT_INJECT_SECRETS__OPENAI_API_KEY=sk-your-key-here
# AGENT_INJECT_SECRETS__ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Scoring ===
# AGENT_INJECT_SCORING__CANARY_MATCH_THRESHOLD=0.8
# AGENT_INJECT_SCORING__USE_LLM_JUDGE=false
# AGENT_INJECT_SCORING__JUDGE_MODEL=gpt-4o-mini

# === Output ===
# AGENT_INJECT_OUTPUT__DIR=./results
# AGENT_INJECT_OUTPUT__FORMAT=json
# AGENT_INJECT_OUTPUT__VERBOSE=false
# AGENT_INJECT_OUTPUT__LOG_LEVEL=WARNING
