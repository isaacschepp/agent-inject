# agent-inject configuration template
#
# SECURITY: This file is NOT auto-loaded from the current directory (CWE-426).
# To use:  agent-inject scan --env-file /path/to/.env ...
# Or place in your XDG config dir:
#   Linux:   ~/.config/agent-inject/.env
#   macOS:   ~/Library/Application Support/agent-inject/.env
#   Windows: %APPDATA%/agent-inject/.env
#
# See: https://github.com/isaacschepp/agent-inject/issues/466

# === Target Configuration ===
# AGENT_INJECT_TARGET_URL=https://your-agent.example.com/chat
# AGENT_INJECT_TARGET_ADAPTER=rest
# AGENT_INJECT_TIMEOUT_SECONDS=30.0

# === Engine Configuration ===
# AGENT_INJECT_MAX_CONCURRENT=5
# AGENT_INJECT_MAX_TURNS=15

# === API Keys (use a secrets manager in production) ===
# AGENT_INJECT_OPENAI_API_KEY=sk-your-key-here
# AGENT_INJECT_ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Scoring ===
# AGENT_INJECT_CANARY_MATCH_THRESHOLD=0.8
# AGENT_INJECT_USE_LLM_JUDGE=false
# AGENT_INJECT_JUDGE_MODEL=gpt-4o-mini

# === Output ===
# AGENT_INJECT_OUTPUT_DIR=./results
# AGENT_INJECT_OUTPUT_FORMAT=json
# AGENT_INJECT_VERBOSE=false
